# HybridChain Node Configuration
# Copy this file to .env and fill in actual values

# === KEY SECURITY PARAMETERS ===
# Must be a 32-byte hex string (64 hex characters)
# This is the seed for the Certificate Authority (mTLS)
# ALL NODES IN THE NETWORK MUST USE THE SAME VALUE
# Example: 00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff
STORAGE_AES_KEY=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff

# Private key for this node (for signing transactions and consensus messages)
# Must be a valid secp256k1 private key in hex format
# Example: a24327eaed4fe735576f1ec2a4c433094d2e88a515ddaf22e2c98a592f0b81d8
NODE_PRIVATE_KEY=a24327eaed4fe735576f1ec2a4c433094d2e88a515ddaf22e2c98a592f0b81d8

# Comma-separated list of validator public keys for this network
# These are the only nodes allowed to participate in consensus
# Example: 0398e0f5fccf41f104eb724ba1f59c6f68043dad84786ddadc38614d635f25282b,02c6047f9441ed7d6d3045406e95c07cd85c778e4b8cef3ca7d20fb651aeb6f72
VALIDATOR_PUBKEYS=0398e0f5fccf41f104eb724ba1f59c6f68043dad84786ddadc38614d635f25282b

# === NETWORK CONFIGURATION ===
# Port for P2P networking
P2P_PORT=6001

# Port for REST API
API_PORT=8000

# Network identifier (must be same for all nodes in the same network)
NETWORK_ID=101

# Is this node a seed node (entry point for new nodes)?
IS_SEED=false

# Seed peer address for joining the network (not needed if IS_SEED=true)
# Format: host:port  Example: 127.0.0.1:6001
SEED_PEER=127.0.0.1:6001

# === NODE CONFIGURATION ===
# Unique identifier for this node
NODE_NAME=HybridChainNode-1

# Path to blockchain data directory
STORAGE_PATH=./data

# === DEBUG/TESTING ===
# Enable debug logging and development mode
DEBUG=false

# === OPTIONAL: PRUNING ===
# Maximum number of blocks to keep (0 = keep all)
# Set to a value like 100000 to run a pruned node
MAX_BLOCKS=0

# === OPTIONAL: MQTT (IoT) ===
# MQTT_BROKER_URL=tcp://localhost:1883
# MQTT_USERNAME=
# MQTT_PASSWORD=

# === SYSTEM ===
# Java heap size (adjust based on load)
# JAVA_OPTS=-Xmx2G -Xms1G
